# ── AI 글 생성 엔진 ──────────────────────────────
# 두 가지 중 하나만 있으면 됩니다:
#  1) Claude Code가 설치된 맥북에서 실행 → 아무것도 설정 안 해도 됨 (Max 요금제에 포함, 추가 비용 없음)
#  2) Claude API 종량제 → 아래 API 키 입력 (console.anthropic.com에서 발급)
# 둘 다 있으면 API를 우선 사용합니다. GENERATION_ENGINE=claude_code 로 강제할 수 있습니다.
ANTHROPIC_API_KEY=

# 생성 엔진 강제 지정 (auto / api / claude_code) - 보통 auto로 두면 됩니다
GENERATION_ENGINE=auto

# Claude Code로 생성할 때 쓸 모델 (sonnet 권장 - Max 사용량을 아낌)
CLAUDE_CODE_MODEL=sonnet

# Telegram (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# WordPress (bokjisosik.com 설정 후 입력)
WP_URL=https://bokjisosik.com
WP_USERNAME=...
WP_APP_PASSWORD=...

# 공공데이터포털 (data.go.kr에서 발급)
PUBLIC_DATA_API_KEY=...

# GitHub (github.com/settings/tokens에서 발급 - repo 권한 필요)
GITHUB_TOKEN=...
GITHUB_REPO=깃허브유저명/bokjisosik

# 웹 대시보드
DASHBOARD_PASSWORD=...
# 텔레그램 알림에 들어갈 대시보드 주소 (Railway 배포 주소)
DASHBOARD_URL=https://...railway.app

# 한 번 실행에 AI가 자동 생성할 글 개수 상한 (비용 통제)
AUTO_GENERATE_LIMIT=5
