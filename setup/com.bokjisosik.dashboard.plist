<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- 복지소식 대시보드 자동 실행 설정
       ⚠️ 아래 두 곳의 "여기에사용자이름"을 실제 맥 사용자 이름으로 바꾸세요.
       (터미널에서 whoami 를 입력하면 사용자 이름이 나옵니다) -->
  <key>Label</key>
  <string>com.bokjisosik.dashboard</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/여기에사용자이름/bokjisosik/run_dashboard.sh</string>
  </array>

  <!-- 맥북이 켜지면 자동 시작 -->
  <key>RunAtLoad</key>
  <true/>

  <!-- 서버가 죽으면 자동 재시작 -->
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/여기에사용자이름/bokjisosik/logs/dashboard.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/여기에사용자이름/bokjisosik/logs/dashboard.log</string>
</dict>
</plist>
